#!/usr/bin/make -f

# Uncomment this to turn on verbose mode.
export DH_VERBOSE=1

build: build-stamp
build-stamp:
	dh_testdir

	# Add here commands to compile the package.
	mkdir -p m4
	autoreconf --install
	# activate the following line to skip coverage analysis (lcov)
	./configure --prefix=/usr --datadir=/usr/share/rds --sharedstatedir=/var/lib/rds
	# activate the following line to get coverage analysis (lcov)
	#./configure --prefix=/usr --datadir=/usr/share/rds --sharedstatedir=/var/lib/rds CFLAGS='-fprofile-arcs -ftest-coverage'
	$(MAKE)
	$(MAKE) man
	#$(MAKE) check	# will fail with fakeroot
	$(MAKE) doxygen
	touch build-stamp

clean:
	dh_testdir
	dh_testroot || true
	dh_clean
	rm -f build-stamp

	# Add here commands to clean up after the build process.
	test -f Makefile && $(MAKE) clean || true
	test -f Makefile && $(MAKE) distclean || true

install: install-stamp
install-stamp: build
	dh_testdir
	dh_testroot
	dh_prep
	dh_installdirs
	dh_auto_install
	touch install-stamp

# Build architecture-independent files here.
binary-indep: build install
# We have nothing to do by default.

# Build architecture-dependent files here.
binary-arch: build install
	dh_testdir
	dh_testroot
	dh_installchangelogs
	dh_installdocs
	dh_installexamples
	dh_install -X.svn -X.git
#	dh_installmenu
#	dh_installdebconf
#	dh_installlogrotate
#	dh_installemacsen
#	dh_installcatalogs
#	dh_installpam
#	dh_installmime
#	dh_installinit
#	dh_installcron
#	dh_installinfo
#	dh_installwm
#	dh_installudev
#	dh_lintian
#	dh_undocumented
	dh_installman
	dh_link
	dh_strip
	dh_compress
	dh_fixperms
	chmod 777 debian/librds/var/lib/rds
	chmod 666 debian/librds/var/lib/rds/rds_program.db
#	dh_perl
#	dh_python
	dh_makeshlibs
	dh_installdeb
	dh_shlibdeps
	dh_gencontrol
	dh_md5sums
	dh_builddeb

binary: binary-indep binary-arch
.PHONY: build clean binary-indep binary-arch binary install
